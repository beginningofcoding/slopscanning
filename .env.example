# SlopScanning — Author: thanos
# Repository: https://github.com/beginningofcoding/slopscanning

# ──────── Client ────────
NEXT_PUBLIC_API_URL=http://localhost:8000


# ──────── Server ────────

# ── Redis (required for API startup) ──
# Local: docker compose up redis  →  redis://localhost:6379/0
# Render: create Redis, copy Internal URL into web service env REDIS_URL
# Option A — full URL (Upstash Connect → redis-cli line, use rediss://)
REDIS_URL=redis://localhost:6379/0
# Option B — Render / Upstash (no URL encoding issues):
# REDIS_HOST=apparent-oriole-94450.upstash.io
# REDIS_PASSWORD=your_upstash_token
# REDIS_TLS=true
# REDIS_PORT=6379

# ── GitHub Token ──
GITHUB_TOKEN=your_github_personal_access_token_here

# ── AI: Fireworks (primary) ──
# Create at https://app.fireworks.ai/settings/users/api-keys
FIREWORKS_API_KEY=your_fireworks_api_key_here
# Recommended: deepseek-v4-pro (best audit quality, 1M context)
# Alternatives: kimi-k2p6 (262k, coding agents), qwen3p6-plus (cheaper, vision)
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro

# ── AI: Gemini (fallback when Fireworks fails or is unset) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Unified audit ──
AUDIT_LLM_BRIEF=true
AUDIT_MAX_CODE_FILES=50
AUDIT_PR_SAMPLE=3
AUDIT_COMMIT_SAMPLE=20

# ── Settings ──
SANDBOX_ROOT=./tmp/sandboxed
MAX_REPO_SIZE_MB=200
SCAN_TIMEOUT_SECONDS=120

# ── CORS ──
CORS_ORIGINS=http://localhost:3000
